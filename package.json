{
  "name": "portfolio-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "dev:server": "pnpm --filter @portfolio/server run dev",
    "dev:web": "pnpm --filter @portfolio/web run dev",
    "build": "pnpm -r run build",
    "build:server": "pnpm --filter @portfolio/server run build",
    "build:web": "pnpm --filter @portfolio/web run build"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp"]
  }
}
