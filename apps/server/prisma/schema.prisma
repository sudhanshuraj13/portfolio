generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model SystemLog {
  id           Int      @id @default(autoincrement())
  trace_id     String
  timestamp    DateTime @default(now())
  microservice String
  action       String
  latency_ms   Int
  status       String   // SUCCESS or ERROR
  metadata     Json?
}
